# ===========================================
# HYPERLIQUID TRADING BOT - CONFIGURAZIONE
# Strategia: Trend 4H/1D Following
# ===========================================

# ===========================================
# CREDENZIALI (OBBLIGATORIE)
# ===========================================
HYPERLIQUID_WALLET_ADDRESS=0xIlTuoWalletAddress
HYPERLIQUID_PRIVATE_KEY=0xLaTuaChiavePrivata
OPENROUTER_API_KEY=sk-or-LaTuaChiaveOpenRouter
DASHBOARD_API_KEY=hyperliquid123-super-secure-key-456
VITE_DASHBOARD_API_KEY=hyperliquid123-super-secure-key-456

# ===========================================
# MODALITÀ TRADING (FAIL-CLOSED)
# ===========================================
EXECUTION_MODE=paper
ENABLE_MAINNET_TRADING=false

# ===========================================
# STRATEGIA TREND 4H/1D (OTTIMIZZATA)
# ===========================================
PRIMARY_TIMEFRAME=4h
SECONDARY_TIMEFRAME=1d
ENTRY_TIMEFRAME=1h
MIN_TREND_DURATION_HOURS=24
VOLUME_CONFIRMATION_THRESHOLD=1.5
TREND_CONFIRMATION_REQUIRED=true
MAX_TREND_POSITIONS=2
TREND_POSITION_SIZE_PCT=0.03
TREND_LEVERAGE_MULTIPLIER=1.0
TREND_SL_PCT=0.05
TREND_TP_PCT=0.10
TREND_BREAK_EVEN_ACTIVATION_PCT=0.03
TREND_TRAILING_ACTIVATION_PCT=0.05
TREND_TRAILING_CALLBACK=0.03

# ===========================================
# COPPIE TRADING (OTTIMIZZATE PER TREND)
# ===========================================
TRADING_PAIRS=BTC,ETH,SOL,BNB,ADA,DOGE,XRP,AVAX,LINK,SUI,ARB,OP,NEAR,WIF,PEPE,INJ,TIA,SEI,RENDER,FET

# ===========================================
# RISCHIO E GESTIONE PORTAFOGLIO
# ===========================================
MAX_ORDER_MARGIN_PCT=0.08
HARD_MAX_LEVERAGE=7
MIN_CONFIDENCE_OPEN=0.72
MIN_CONFIDENCE_MANAGE=0.50
MAX_MARGIN_USAGE=0.70
MAX_DRAWDOWN_PCT=0.12
MAX_SINGLE_ASSET_PCT=0.35
EMERGENCY_MARGIN_THRESHOLD=0.85
TRADE_COOLDOWN_SEC=300
DAILY_NOTIONAL_LIMIT_USD=500
MAX_TRADES_PER_CYCLE=2
MAX_CONSECUTIVE_FAILED_CYCLES=5
PAPER_SLIPPAGE_BPS=5
VOLATILITY_MULTIPLIER=1.2
SAFE_FALLBACK_MODE=hold

# ===========================================
# GESTIONE POSIZIONI (TREND-SPECIFIC)
# ===========================================
DEFAULT_SL_PCT=0.03
DEFAULT_TP_PCT=0.05
DEFAULT_TRAILING_CALLBACK=0.02
ENABLE_TRAILING_STOP=true
TRAILING_ACTIVATION_PCT=0.02
BREAK_EVEN_ACTIVATION_PCT=0.015
BREAK_EVEN_OFFSET_PCT=0.001

# ===========================================
# CICLO ADATTIVO (OTTIMIZZATO PER TREND)
# ===========================================
ENABLE_ADAPTIVE_CYCLE=true
DEFAULT_CYCLE_SEC=120
MIN_CYCLE_SEC=30
MAX_CYCLE_SEC=300

# ===========================================
# CORRELAZIONE ASSET
# ===========================================
CORRELATION_THRESHOLD=0.7

# ===========================================
# API E CONNESSIONI
# ===========================================
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_INFO_TIMEOUT=15
HYPERLIQUID_EXCHANGE_TIMEOUT=30
META_CACHE_TTL_SEC=120

# ===========================================
# LLM (CLAUDE OPUS 4.6 OTTIMIZZATO)
# ===========================================
LLM_MODEL=anthropic/claude-opus-4
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.15

# ===========================================
# LOGGING E MONITORAGGIO
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=logs/hyperliquid_bot.log

# ===========================================
# DASHBOARD E API
# ===========================================
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=5000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===========================================
# TELEGRAM (OPZIONALE)
# ===========================================
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# ===========================================
# NOTA IMPORTANTE
# ===========================================
# 1. Copia questo file in .env: cp .env.example .env
# 2. Compila le credenziali obbligatorie
# 3. Testa con: python scripts/test_connection.py
# 4. Avvia con: python hyperliquid_bot_executable_orders.py --single-cycle