# ============================================================================
# HYPERLIQUID TRADING BOT - ENVIRONMENT VARIABLES
# ============================================================================
# NEVER commit this file or share it publicly!
# Copy to .env and fill in your values
# ============================================================================

# ============================================================================
# 1. HYPERLIQUID CREDENTIALS (REQUIRED)
# ============================================================================

# Your Hyperliquid wallet address (0x...)
HYPERLIQUID_WALLET_ADDRESS=0xYourWalletAddressHere

# Your Hyperliquid private key (0x...)
HYPERLIQUID_PRIVATE_KEY=0xYourPrivateKeyHere

# Hyperliquid API base URL (use testnet for testing)
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
# HYPERLIQUID_BASE_URL=https://api.hyperliquid-testnet.xyz  # Testnet

# API timeouts (seconds)
HYPERLIQUID_INFO_TIMEOUT=15
HYPERLIQUID_EXCHANGE_TIMEOUT=30

# ============================================================================
# 2. LLM CONFIGURATION (OpenRouter)
# ============================================================================

# OpenRouter API key (get from https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-YourOpenRouterAPIKeyHere

# LLM model to use
LLM_MODEL=anthropic/claude-opus-4

# LLM parameters
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.15

# ============================================================================
# 3. DASHBOARD SECURITY (REQUIRED)
# ============================================================================

# API key for dashboard authentication (generate a secure random string)
# Must be the same in both variables below!
DASHBOARD_API_KEY=hyperliquid123-super-secure-key-456
VITE_DASHBOARD_API_KEY=hyperliquid123-super-secure-key-456

# CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API server configuration
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=5000

# ============================================================================
# 4. TRADING MODE & SAFETY
# ============================================================================

# Execution mode: 'paper' (simulated) or 'live' (real trading)
EXECUTION_MODE=paper

# Enable mainnet trading (REQUIRES EXECUTION_MODE=live)
ENABLE_MAINNET_TRADING=false

# Safe fallback mode when LLM fails: 'hold' or 'de_risk'
SAFE_FALLBACK_MODE=hold

# ============================================================================
# 5. TRADING PAIRS & ASSETS
# ============================================================================

# Comma-separated list of trading pairs
TRADING_PAIRS=BTC,ETH,SOL,BNB,ADA,DOGE,XRP,AVAX,LINK,SUI,ARB,OP,NEAR,WIF,PEPE,INJ,TIA,SEI,RENDER,FET

# ============================================================================
# 6. RISK MANAGEMENT
# ============================================================================

# Maximum drawdown percentage (0.12 = 12%)
MAX_DRAWDOWN_PCT=0.12

# Maximum margin usage (0.8 = 80%)
MAX_MARGIN_USAGE=0.8

# Maximum single asset exposure (0.35 = 35%)
MAX_SINGLE_ASSET_PCT=0.35

# Emergency margin threshold (0.85 = 85%)
EMERGENCY_MARGIN_THRESHOLD=0.85

# Maximum leverage allowed
HARD_MAX_LEVERAGE=7

# Maximum order margin percentage (0.08 = 8%)
MAX_ORDER_MARGIN_PCT=0.08

# Minimum confidence for opening positions (0.72 = 72%)
MIN_CONFIDENCE_OPEN=0.72

# Minimum confidence for managing positions (0.5 = 50%)
MIN_CONFIDENCE_MANAGE=0.5

# Trade cooldown in seconds
TRADE_COOLDOWN_SEC=300

# Daily notional limit in USD
DAILY_NOTIONAL_LIMIT_USD=500

# Maximum trades per cycle
MAX_TRADES_PER_CYCLE=2

# Maximum consecutive failed cycles before shutdown
MAX_CONSECUTIVE_FAILED_CYCLES=5

# Paper trading slippage in basis points (5 = 0.05%)
PAPER_SLIPPAGE_BPS=5

# Volatility multiplier for position sizing
VOLATILITY_MULTIPLIER=1.2

# ============================================================================
# 7. POSITION MANAGEMENT (SL/TP/TRAILING/BREAK-EVEN)
# ============================================================================

# Default stop-loss percentage (0.03 = 3%)
DEFAULT_SL_PCT=0.03

# Default take-profit percentage (0.05 = 5%)
DEFAULT_TP_PCT=0.05

# Default trailing stop callback percentage (0.02 = 2%)
DEFAULT_TRAILING_CALLBACK=0.02

# Enable trailing stops
ENABLE_TRAILING_STOP=true

# Trailing stop activation percentage (0.02 = 2%)
TRAILING_ACTIVATION_PCT=0.02

# Break-even activation percentage (0.015 = 1.5%)
BREAK_EVEN_ACTIVATION_PCT=0.015

# Break-even offset percentage (0.001 = 0.1%)
BREAK_EVEN_OFFSET_PCT=0.001

# ============================================================================
# 8. CYCLE & TIMING
# ============================================================================

# Enable adaptive cycle timing based on volatility
ENABLE_ADAPTIVE_CYCLE=true

# Default cycle duration in seconds
DEFAULT_CYCLE_SEC=120

# Minimum cycle duration in seconds
MIN_CYCLE_SEC=30

# Maximum cycle duration in seconds
MAX_CYCLE_SEC=300

# Correlation threshold for risk management (0.7 = 70%)
CORRELATION_THRESHOLD=0.7

# Meta cache TTL in seconds
META_CACHE_TTL_SEC=120

# ============================================================================
# 9. LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/hyperliquid_bot.log

# ============================================================================
# 10. TELEGRAM NOTIFICATIONS (OPTIONAL)
# ============================================================================

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID (your user/group ID)
TELEGRAM_CHAT_ID=

# ============================================================================
# 11. ADVANCED SETTINGS (Only change if you know what you're doing)
# ============================================================================

# Allow external LLM calls (set to false for complete offline mode)
ALLOW_EXTERNAL_LLM=true

# Include portfolio context in LLM prompts
LLM_INCLUDE_PORTFOLIO_CONTEXT=true

# Auto-confirm minimal orders (DANGEROUS - only for testing)
AUTO_CONFIRM_MINIMAL_ORDER=false

# Maximum market data age in seconds
MAX_MARKET_DATA_AGE_SEC=300