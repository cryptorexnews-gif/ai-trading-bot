# ============================================================
# Hyperliquid Trading Bot - Configuration
# ============================================================

# === REQUIRED ===
HYPERLIQUID_PRIVATE_KEY=your_private_key_here
HYPERLIQUID_WALLET_ADDRESS=your_wallet_address_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# === Execution Mode ===
# paper = simulated trades, live = real trades
EXECUTION_MODE=paper
ENABLE_MAINNET_TRADING=false

# === Hyperliquid API ===
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_INFO_TIMEOUT=15
HYPERLIQUID_EXCHANGE_TIMEOUT=30

# === AI / LLM Settings ===
LLM_MODEL=anthropic/claude-opus-4.6
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.15
ALLOW_EXTERNAL_LLM=true
LLM_INCLUDE_PORTFOLIO_CONTEXT=true

# === Risk Management (Optimized for Profitability) ===
MAX_ORDER_MARGIN_PCT=0.15
HARD_MAX_LEVERAGE=10
MIN_CONFIDENCE_OPEN=0.72
MIN_CONFIDENCE_MANAGE=0.50
MAX_MARGIN_USAGE=0.75
MAX_DRAWDOWN_PCT=0.12
TRADE_COOLDOWN_SEC=180
DAILY_NOTIONAL_LIMIT_USD=2000
MAX_TRADES_PER_CYCLE=3
MAX_CONSECUTIVE_FAILED_CYCLES=10
META_CACHE_TTL_SEC=300
MAX_MARKET_DATA_AGE_SEC=300
PAPER_SLIPPAGE_BPS=30
SAFE_FALLBACK_MODE=hold

# === Stop-Loss / Take-Profit / Trailing (Asymmetric R:R) ===
# Tight SL to cut losers fast, wide TP to let winners run
DEFAULT_SL_PCT=0.02
DEFAULT_TP_PCT=0.06
DEFAULT_TRAILING_CALLBACK=0.015
ENABLE_TRAILING_STOP=true
TRAILING_ACTIVATION_PCT=0.025

# === Adaptive Cycle ===
ENABLE_ADAPTIVE_CYCLE=true
MIN_CYCLE_SEC=15
MAX_CYCLE_SEC=90
DEFAULT_CYCLE_SEC=45

# === Correlation ===
CORRELATION_THRESHOLD=0.65

# === Telegram Notifications ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === API Server ===
API_SERVER_PORT=5000

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/hyperliquid_bot.log
LOG_JSON_FORMAT=true