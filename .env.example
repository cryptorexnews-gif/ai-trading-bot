# Hyperliquid Trading Bot - Environment Configuration (.env)
# Copy this to .env and FILL YOUR VALUES! (never commit .env)

# ========================================
# HYPERLIQUID CREDENTIALS (REQUIRED)
# ========================================
HYPERLIQUID_WALLET_ADDRESS=0x1234567890abcdef1234567890abcdef12345678
HYPERLIQUID_PRIVATE_KEY=0xabcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890

# ========================================
# LLM (Claude Opus - REQUIRED for AI)
# ========================================
OPENROUTER_API_KEY=sk-or-v1-abcdefghijklmnopqrstuvwxyz1234567890

# ========================================
# DASHBOARD API KEY (REQUIRED for LIVE MODE)
# ========================================
# SAME KEY for BOTH backend AND frontend!
# Backend uses: DASHBOARD_API_KEY
# Frontend uses: VITE_DASHBOARD_API_KEY (Vite prefix required)
# Generate 32+ chars: https://generate-secret.vercel.app/32
DASHBOARD_API_KEY=hyperliquid-bot-super-secure-key-2024-ABC123def456GHI789
VITE_DASHBOARD_API_KEY=hyperliquid-bot-super-secure-key-2024-ABC123def456GHI789

# ========================================
# TRADING MODE
# ========================================
EXECUTION_MODE=paper          # paper (SAFE) or live (REAL orders)
ENABLE_MAINNET_TRADING=false  # ⚠️ true = REAL MONEY!

# ========================================
# TRADING PAIRS
# ========================================
TRADING_PAIRS=BTC,ETH,SOL,BNB,ADA,DOGE,XRP,AVAX,LINK,SUI,ARB,OP,NEAR,WIF,PEPE

# ========================================
# RISK LIMITS
# ========================================
MAX_DRAWDOWN_PCT=0.12         # Emergency stop at 12%
DAILY_NOTIONAL_LIMIT_USD=500
HARD_MAX_LEVERAGE=7

# ========================================
# RISK:REWARD
# ========================================
DEFAULT_SL_PCT=0.03           # Stop Loss 3%
DEFAULT_TP_PCT=0.05           # Take Profit 5%

# ========================================
# CYCLE SPEED
# ========================================
DEFAULT_CYCLE_SEC=120         # 2 minutes per cycle

# ========================================
# TELEGRAM (OPTIONAL)
# ========================================
# TELEGRAM_BOT_TOKEN=1234567890:ABC...
# TELEGRAM_CHAT_ID=123456789