# ═══════════════════════════════════════════════════════════════════════════════
# HYPERLIQUID AI TRADING BOT — CONFIGURAZIONE AMBIENTE
# ═══════════════════════════════════════════════════════════════════════════════
# Copia questo file come .env e compila i valori obbligatori.
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ─── OBBLIGATORIO: Credenziali Hyperliquid ────────────────────────────────────
# La tua chiave privata Hyperliquid (NON condividere mai!)
HYPERLIQUID_PRIVATE_KEY=

# Il tuo indirizzo wallet (deve corrispondere alla chiave privata)
HYPERLIQUID_WALLET_ADDRESS=

# ─── OBBLIGATORIO: API Key OpenRouter (per Claude Opus 4.6) ──────────────────
OPENROUTER_API_KEY=

# ─── Modalità Esecuzione ──────────────────────────────────────────────────────
# "paper" = ordini simulati su dati reali (SICURO per test)
# "live"  = ordini reali sull'exchange (USA CON CAUTELA)
EXECUTION_MODE=paper

# Doppio interruttore di sicurezza: deve essere "true" per ordini reali
# Anche con EXECUTION_MODE=live, se questo è false gli ordini sono simulati
ENABLE_MAINNET_TRADING=false

# ─── Connessione Hyperliquid ──────────────────────────────────────────────────
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_INFO_TIMEOUT=15
HYPERLIQUID_EXCHANGE_TIMEOUT=30

# ─── Modello LLM ─────────────────────────────────────────────────────────────
LLM_MODEL=anthropic/claude-opus-4
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.15

# ─── Coppie di Trading ───────────────────────────────────────────────────────
# Separa con virgola. Per test iniziale, usa poche coin per risparmiare API calls.
# Ogni coin = 1 chiamata LLM per ciclo (~$0.02-0.05 per chiamata con Opus)
TRADING_PAIRS=BTC,ETH,SOL

# ─── Ciclo di Trading ────────────────────────────────────────────────────────
# Secondi tra un ciclo e l'altro (più alto = meno costi LLM)
DEFAULT_CYCLE_SEC=120
ENABLE_ADAPTIVE_CYCLE=true
MIN_CYCLE_SEC=30
MAX_CYCLE_SEC=300

# ─── Risk Management ─────────────────────────────────────────────────────────
# Percentuale massima del saldo per singolo ordine (10% = conservativo)
MAX_ORDER_MARGIN_PCT=0.08

# Leverage massimo consentito (il bot non supererà mai questo valore)
HARD_MAX_LEVERAGE=7

# Confidenza minima LLM per aprire nuove posizioni (0.72 = conservativo)
MIN_CONFIDENCE_OPEN=0.72

# Confidenza minima per gestire posizioni esistenti (close/reduce)
MIN_CONFIDENCE_MANAGE=0.50

# Uso margine massimo prima di bloccare nuovi trade
MAX_MARGIN_USAGE=0.70

# Drawdown massimo dal picco prima di bloccare nuovi trade
MAX_DRAWDOWN_PCT=0.12

# Percentuale massima su singolo asset
MAX_SINGLE_ASSET_PCT=0.35

# Soglia margine per de-risk di emergenza (chiude posizione peggiore)
EMERGENCY_MARGIN_THRESHOLD=0.85

# Cooldown tra trade sullo stesso asset (secondi)
TRADE_COOLDOWN_SEC=300

# Limite notionale giornaliero totale (USD)
DAILY_NOTIONAL_LIMIT_USD=500

# Massimo trade per ciclo
MAX_TRADES_PER_CYCLE=2

# Cicli falliti consecutivi prima di shutdown
MAX_CONSECUTIVE_FAILED_CYCLES=5

# Slippage simulato in paper mode (basis points, 5 = 0.05%)
PAPER_SLIPPAGE_BPS=5

# Moltiplicatore volatilità per sizing (1.2 = riduce size in alta volatilità)
VOLATILITY_MULTIPLIER=1.2

# Azione fallback quando LLM non disponibile: "de_risk" o "hold"
SAFE_FALLBACK_MODE=hold

# ─── Stop-Loss / Take-Profit / Trailing ──────────────────────────────────────
# Stop-loss predefinito (3% = conservativo)
DEFAULT_SL_PCT=0.03

# Take-profit predefinito (5% = R:R 1:1.67)
DEFAULT_TP_PCT=0.05

# Trailing stop callback (2% dal massimo)
DEFAULT_TRAILING_CALLBACK=0.02
ENABLE_TRAILING_STOP=true

# Attivazione trailing dopo +2% profitto
TRAILING_ACTIVATION_PCT=0.02

# Break-even: sposta SL a entry dopo +1.5% profitto
BREAK_EVEN_ACTIVATION_PCT=0.015
BREAK_EVEN_OFFSET_PCT=0.001

# ─── Correlazione ────────────────────────────────────────────────────────────
# Soglia correlazione per bloccare posizioni nella stessa direzione
CORRELATION_THRESHOLD=0.7

# ─── Cache ────────────────────────────────────────────────────────────────────
META_CACHE_TTL_SEC=120

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/hyperliquid_bot.log

# ─── Dashboard API ────────────────────────────────────────────────────────────
# Chiave API per proteggere la dashboard (opzionale in paper mode)
# OBBLIGATORIA quando EXECUTION_MODE=live
DASHBOARD_API_KEY=

# Host e porta del server API dashboard
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=5000

# Origini CORS consentite (separa con virgola)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Telegram (opzionale) ────────────────────────────────────────────────────
# Per ricevere notifiche trade su Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=