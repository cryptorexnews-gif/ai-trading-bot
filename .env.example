# === REQUIRED: Hyperliquid ===
HYPERLIQUID_PRIVATE_KEY=your_private_key_here
HYPERLIQUID_WALLET_ADDRESS=your_wallet_address_here
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_INFO_TIMEOUT=15
HYPERLIQUID_EXCHANGE_TIMEOUT=30

# === REQUIRED: LLM (OpenRouter) ===
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=anthropic/claude-opus-4.6
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.15

# === Execution Mode ===
EXECUTION_MODE=paper
ENABLE_MAINNET_TRADING=false

# === Trading Pairs (20 top Hyperliquid pairs) ===
# Tier 1 Blue Chips: BTC, ETH, SOL
# Tier 2 Large Caps: BNB, XRP, ADA, DOGE, AVAX, LINK, NEAR
# Tier 3 L2/Infra:   SUI, ARB, OP, SEI, TIA, INJ
# Tier 4 Narrative:   WIF, PEPE, RENDER, FET
TRADING_PAIRS=BTC,ETH,SOL,BNB,ADA,DOGE,XRP,AVAX,LINK,SUI,ARB,OP,NEAR,WIF,PEPE,INJ,TIA,SEI,RENDER,FET

# === Risk Management ===
MAX_ORDER_MARGIN_PCT=0.1
HARD_MAX_LEVERAGE=10
MIN_CONFIDENCE_OPEN=0.72
MIN_CONFIDENCE_MANAGE=0.50
MAX_MARGIN_USAGE=0.8
MAX_DRAWDOWN_PCT=0.15
MAX_SINGLE_ASSET_PCT=0.40
EMERGENCY_MARGIN_THRESHOLD=0.88
TRADE_COOLDOWN_SEC=300
DAILY_NOTIONAL_LIMIT_USD=1000
MAX_TRADES_PER_CYCLE=3
MAX_CONSECUTIVE_FAILED_CYCLES=5
PAPER_SLIPPAGE_BPS=5
VOLATILITY_MULTIPLIER=1.2

# === SL/TP/Trailing ===
DEFAULT_SL_PCT=0.03
DEFAULT_TP_PCT=0.05
DEFAULT_TRAILING_CALLBACK=0.02
ENABLE_TRAILING_STOP=true
TRAILING_ACTIVATION_PCT=0.02

# === Adaptive Cycle ===
ENABLE_ADAPTIVE_CYCLE=true
DEFAULT_CYCLE_SEC=60
MIN_CYCLE_SEC=20
MAX_CYCLE_SEC=180

# === Correlation ===
CORRELATION_THRESHOLD=0.7

# === Cache ===
META_CACHE_TTL_SEC=120
MAX_MARKET_DATA_AGE_SEC=300

# === Safe Fallback ===
SAFE_FALLBACK_MODE=de_risk
ALLOW_EXTERNAL_LLM=true
LLM_INCLUDE_PORTFOLIO_CONTEXT=true

# === Telegram Notifications (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === API Server ===
API_SERVER_PORT=5000

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/hyperliquid_bot.log

# === Minimal Order Testing ===
AUTO_CONFIRM_MINIMAL_ORDER=false