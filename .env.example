# Core
EXECUTION_MODE=live
ENABLE_MAINNET_TRADING=false
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_INFO_TIMEOUT=15
HYPERLIQUID_EXCHANGE_TIMEOUT=30

# Wallet / API keys
HYPERLIQUID_WALLET_ADDRESS=0xYOUR_WALLET
HYPERLIQUID_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
DASHBOARD_API_KEY=YOUR_DASHBOARD_KEY

# LLM
LLM_MODEL=deepseek/deepseek-v3.2
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.2

# Trading universe
TRADING_PAIRS=BTC,ETH,SOL,BNB,ADA,DOGE,XRP,AVAX,LINK,SUI,ARB,OP,NEAR,WIF,PEPE,INJ,TIA,SEI,RENDER,FET

# Base trend profile
DEFAULT_CYCLE_SEC=1800
MIN_CYCLE_SEC=900
MAX_CYCLE_SEC=3600
MAX_TRADES_PER_CYCLE=2
HARD_MAX_LEVERAGE=10
MIN_CONFIDENCE_OPEN=0.72
MIN_CONFIDENCE_MANAGE=0.50
MAX_MARGIN_USAGE=0.8
MAX_ORDER_MARGIN_PCT=0.1
MAX_ORDER_NOTIONAL_USD=0
TRADE_COOLDOWN_SEC=300
DAILY_NOTIONAL_LIMIT_USD=1000
VOLATILITY_MULTIPLIER=1.2
MAX_DRAWDOWN_PCT=0.15
MAX_SINGLE_ASSET_PCT=0.35
EMERGENCY_MARGIN_THRESHOLD=0.88

# Trend strategy params
PRIMARY_TIMEFRAME=4h
SECONDARY_TIMEFRAME=1d
ENTRY_TIMEFRAME=1h
MIN_TREND_DURATION_HOURS=36
VOLUME_CONFIRMATION_THRESHOLD=1.6
TREND_CONFIRMATION_REQUIRED=true
MAX_TREND_POSITIONS=2
TREND_POSITION_SIZE_PCT=0.02
TREND_LEVERAGE_MULTIPLIER=0.9
TREND_SL_PCT=0.04
TREND_TP_PCT=0.08
TREND_BREAK_EVEN_ACTIVATION_PCT=0.02
TREND_TRAILING_ACTIVATION_PCT=0.03
TREND_TRAILING_CALLBACK=0.02

# Runtime strategy default (trend | scalping)
DEFAULT_STRATEGY_MODE=trend

# ─── Scalping strategy profile (used when strategy_mode=scalping) ────────────
SCALPING_DEFAULT_CYCLE_SEC=300
SCALPING_MIN_CYCLE_SEC=300
SCALPING_MAX_CYCLE_SEC=900
SCALPING_MAX_TRADES_PER_CYCLE=3
SCALPING_HARD_MAX_LEVERAGE=2
SCALPING_MIN_CONFIDENCE_OPEN=0.66
SCALPING_MIN_CONFIDENCE_MANAGE=0.45
SCALPING_MAX_ORDER_MARGIN_PCT=0.06
SCALPING_TRADE_COOLDOWN_SEC=120
SCALPING_DAILY_NOTIONAL_LIMIT_USD=25
SCALPING_MAX_DRAWDOWN_PCT=0.08
SCALPING_MAX_SINGLE_ASSET_PCT=0.25
SCALPING_EMERGENCY_MARGIN_THRESHOLD=0.80
SCALPING_POSITION_SIZE_PCT=0.01
SCALPING_VOLUME_CONFIRMATION_THRESHOLD=1.2
SCALPING_SL_PCT=0.02
SCALPING_TP_PCT=0.04
SCALPING_BREAK_EVEN_ACTIVATION_PCT=0.01
SCALPING_TRAILING_ACTIVATION_PCT=0.015
SCALPING_TRAILING_CALLBACK=0.01

# Misc
ENABLE_ADAPTIVE_CYCLE=true
ENABLE_TRAILING_STOP=true
BREAK_EVEN_OFFSET_PCT=0.001
CORRELATION_THRESHOLD=0.7
META_CACHE_TTL_SEC=86400
PAPER_SLIPPAGE_BPS=5
LOG_LEVEL=INFO
LOG_FILE=logs/hyperliquid_bot.log
STATE_PATH=state/bot_state.json
METRICS_PATH=state/bot_metrics.json