# Hyperliquid Trading Bot - Environment Configuration
# Copy this to .env and FILL IN YOUR VALUES (never commit .env!)

# ========================================
# HYPERLIQUID (REQUIRED)
# ========================================
HYPERLIQUID_WALLET_ADDRESS=0x1234567890abcdef1234567890abcdef12345678
HYPERLIQUID_PRIVATE_KEY=0xabcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890

# ========================================
# OPENROUTER LLM (REQUIRED for AI decisions)
# ========================================
OPENROUTER_API_KEY=sk-or-v1-abcdefghijklmnopqrstuvwxyz1234567890

# ========================================
# DASHBOARD SECURITY (REQUIRED for EXECUTION_MODE=live)
# ========================================
# Set a strong random key (32+ chars). Same key in backend .env and frontend VITE_DASHBOARD_API_KEY
DASHBOARD_API_KEY=H9@kL$7mN#pQ2!rT8vY3wX5zB4&cD6*fG1

# ========================================
# EXECUTION MODE
# ========================================
EXECUTION_MODE=paper          # 'paper' (simulated, safe) or 'live' (real orders)
ENABLE_MAINNET_TRADING=false  # ⚠️ true = REAL MONEY TRADING!

# ========================================
# TRADING PAIRS
# ========================================
TRADING_PAIRS=BTC,ETH,SOL,BNB,ADA,DOGE,XRP,AVAX,LINK,SUI,ARB,OP,NEAR,WIF,PEPE,INJ,TIA,SEI,RENDER,FET

# ========================================
# RISK MANAGEMENT (adjust as needed)
# ========================================
MAX_DRAWDOWN_PCT=0.12         # 12% max portfolio drawdown → emergency stop
DAILY_NOTIONAL_LIMIT_USD=500  # Max daily trade volume
HARD_MAX_LEVERAGE=7           # Max leverage per position
MAX_MARGIN_USAGE=0.70         # Max margin usage before pausing
MAX_SINGLE_ASSET_PCT=0.35     # Max exposure per asset
TRADE_COOLDOWN_SEC=300        # 5min cooldown between same-coin trades

# ========================================
# POSITION MANAGEMENT (Risk:Reward)
# ========================================
DEFAULT_SL_PCT=0.03           # 3% Stop Loss
DEFAULT_TP_PCT=0.05           # 5% Take Profit (1:1.67 R:R base)
ENABLE_TRAILING_STOP=true     # Enable trailing stops
DEFAULT_TRAILING_CALLBACK=0.02 # 2% trailing callback
BREAK_EVEN_ACTIVATION_PCT=0.015 # Move SL to breakeven at +1.5%

# ========================================
# CYCLE TIMING
# ========================================
DEFAULT_CYCLE_SEC=120         # Default cycle interval (2min)
ENABLE_ADAPTIVE_CYCLE=true    # Adjust cycle based on volatility (30-300s)

# ========================================
# LOGGING & STATE
# ========================================
LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/hyperliquid_bot.log

# ========================================
# OPTIONAL: Telegram Alerts
# ========================================
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ========================================
# ADVANCED (leave defaults usually)
# ========================================
MIN_CONFIDENCE_OPEN=0.72
MIN_CONFIDENCE_MANAGE=0.50
MAX_TRADES_PER_CYCLE=2
CORRELATION_THRESHOLD=0.7
META_CACHE_TTL_SEC=120
PAPER_SLIPPAGE_BPS=5