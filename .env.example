# ============================================================
# Hyperliquid Trading Bot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# === REQUIRED: Hyperliquid Credentials ===

HYPERLIQUID_PRIVATE_KEY=977b9b7673cfad0fc87f068db4b4731329e64b4513620f7e9bccfe298e256aef
HYPERLIQUID_WALLET_ADDRESS=0x9b70DcEc4f3dBf6952f2CD070eF2F04c3ea11970


# === REQUIRED: LLM API Key ===
# OpenRouter API key for Claude Opus 4.6 access

OPENROUTER_API_KEY=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

# === Security: Dashboard API Authentication ===
# Set this to protect dashboard API endpoints with X-API-Key header.
# If not set, API endpoints are unauthenticated (development mode only).
# Generate a random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_API_KEY=

# === Security: CORS Allowed Origins ===
# Comma-separated list of allowed origins for the dashboard.
# Default: http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Execution Mode ===
# paper = simulated trades (safe for testing)
# live = real trades on Hyperliquid (requires ENABLE_MAINNET_TRADING=true)
EXECUTION_MODE=paper
ENABLE_MAINNET_TRADING=false

# === Hyperliquid API ===
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_INFO_TIMEOUT=15
HYPERLIQUID_EXCHANGE_TIMEOUT=30

# === LLM Settings ===
LLM_MODEL=anthropic/claude-opus-4.6
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.15

# === Trading Pairs ===
TRADING_PAIRS=BTC,ETH,SOL,BNB,ADA,DOGE,XRP,AVAX,LINK,SUI,ARB,OP,NEAR,WIF,PEPE,INJ,TIA,SEI,RENDER,FET

# === Risk Management ===
MAX_ORDER_MARGIN_PCT=0.1
HARD_MAX_LEVERAGE=10
MIN_CONFIDENCE_OPEN=0.72
MIN_CONFIDENCE_MANAGE=0.50
MAX_MARGIN_USAGE=0.8
MAX_DRAWDOWN_PCT=0.15
MAX_SINGLE_ASSET_PCT=0.40
EMERGENCY_MARGIN_THRESHOLD=0.88
TRADE_COOLDOWN_SEC=300
DAILY_NOTIONAL_LIMIT_USD=1000
MAX_TRADES_PER_CYCLE=3
MAX_CONSECUTIVE_FAILED_CYCLES=5
PAPER_SLIPPAGE_BPS=5
VOLATILITY_MULTIPLIER=1.2
SAFE_FALLBACK_MODE=de_risk

# === Stop-Loss / Take-Profit / Trailing / Break-Even ===
DEFAULT_SL_PCT=0.03
DEFAULT_TP_PCT=0.05
ENABLE_TRAILING_STOP=true
DEFAULT_TRAILING_CALLBACK=0.02
TRAILING_ACTIVATION_PCT=0.02
BREAK_EVEN_ACTIVATION_PCT=0.015
BREAK_EVEN_OFFSET_PCT=0.001

# === Adaptive Cycle ===
ENABLE_ADAPTIVE_CYCLE=true
DEFAULT_CYCLE_SEC=60
MIN_CYCLE_SEC=20
MAX_CYCLE_SEC=180

# === Correlation ===
CORRELATION_THRESHOLD=0.7

# === Cache ===
META_CACHE_TTL_SEC=120

# === API Server ===
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=5000

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/hyperliquid_bot.log

# === Telegram Notifications (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Minimal Order Test (optional) ===
AUTO_CONFIRM_MINIMAL_ORDER=false